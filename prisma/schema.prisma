generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===============================================
// ENUM GÊNERO
// ===============================================
enum Gender {
  MASCULINO
  FEMININO
}

// ===============================================
// MEMBRO (Member)
// ===============================================
model Member {
  id        Int       @id @default(autoincrement())
  name      String
  email     String?   @unique
  username  String?   @unique
  password  String?
  phone     String?
  birthDate DateTime?
  gender    Gender?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  profileImageUrl String?

  // Relacionamentos
  ministries    MemberMinistry[]
  societies     MemberSociety[]

  bibleSchoolClassId Int?
  bibleSchoolClass   BibleSchoolClass? @relation(fields: [bibleSchoolClassId], references: [id], onDelete: SetNull)

  council   MemberCouncil?
  diaconate MemberDiaconate?

  attendances         Attendance[]
  teachingAssignments ClassTeacher[] @relation(name: "TeachingAssignments")
  scheduleAssignments DiaconateScheduleMember[]
  unavailabilities    DiaconateUnavailability[]
  bibleSchoolAttendances BibleSchoolAttendance[]
}

// ===============================================
// CONSELHO (Council)
// ===============================================
model Council {
  id       Int             @id @default(1)
  members  MemberCouncil[]
  finances Finance[]

  documents Document[]
  albums    GalleryAlbum[]
}

// ===============================================
// DIACONIA (Diaconate)
// ===============================================
model Diaconate {
  id      Int               @id @default(1)
  members MemberDiaconate[]

  documents  Document[]
  albums     GalleryAlbum[]
  tasks      DiaconateTask[]
  inventory  DiaconateInventory[]
  schedules  DiaconateSchedule[]
}

// ===============================================
// RELAÇÃO MEMBRO ↔ CONSELHO
// ===============================================
model MemberCouncil {
  id        Int @id @default(autoincrement())
  memberId  Int @unique
  councilId Int
  cargo     String?   // Presidente, Vice-Presidente, Secretário, Tesoureiro, etc.

  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  council Council @relation(fields: [councilId], references: [id], onDelete: Cascade)
}

// ===============================================
// RELAÇÃO MEMBRO ↔ DIACONIA
// ===============================================
model MemberDiaconate {
  id          Int @id @default(autoincrement())
  memberId    Int @unique
  diaconateId Int
  cargo       String?   // Presidente, Vice-Presidente, Secretário, Tesoureiro, etc.

  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  diaconate Diaconate @relation(fields: [diaconateId], references: [id], onDelete: Cascade)
}

// ===============================================
// MINISTÉRIOS (Ministry)
// ===============================================
model Ministry {
  id      Int              @id @default(autoincrement())
  name    String
  members MemberMinistry[]

  documents Document[]
  albums    GalleryAlbum[]
}

model MemberMinistry {
  id         Int @id @default(autoincrement())
  memberId   Int
  ministryId Int

  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@unique([memberId, ministryId])
}

// ===============================================
// SOCIEDADES INTERNAS (InternalSociety)
// ===============================================
model InternalSociety {
  id            Int             @id @default(autoincrement())
  name          String
  members       MemberSociety[]
  visitors      Visitor[]
  finances   Finance[]
  events     Event[]
  broadcasts Broadcast[]
  documents  Document[]
  albums     GalleryAlbum[]
}

model MemberSociety {
  id        Int @id @default(autoincrement())
  memberId  Int
  societyId Int
  cargo     String?   // Presidente, Vice-Presidente, 1º Secretário, 2º Secretário, Tesoureiro, etc.
  joinedAt  DateTime? @default(now())

  member  Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  society InternalSociety @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([memberId, societyId])
}

// ===============================================
// ESCOLA BÍBLICA (BibleSchool)
// ===============================================
model BibleSchool {
  id      Int                @id @default(1)
  classes BibleSchoolClass[] @relation(name: "BibleSchoolClasses")
}

// ===============================================
// CLASSES DA ESCOLA BÍBLICA (BibleSchoolClass)
// ===============================================
model BibleSchoolClass {
  id   Int    @id @default(autoincrement())
  name String

  members  Member[]
  teachers ClassTeacher[]
  lessons  BibleSchoolLesson[]

  bibleSchoolId Int?
  bibleSchool   BibleSchool? @relation(name: "BibleSchoolClasses", fields: [bibleSchoolId], references: [id], onDelete: SetNull)

  documents Document[]
  albums    GalleryAlbum[]
}

// ===============================================
// AULA DA ESCOLA BÍBLICA (chamada por turma / domingo)
// ===============================================
model BibleSchoolLesson {
  id        Int      @id @default(autoincrement())
  classId   Int
  date      DateTime // o domingo da aula (normalizado a 00:00)
  topic     String?  // lição/tema (opcional)
  notes     String?
  createdAt DateTime @default(now())

  class       BibleSchoolClass        @relation(fields: [classId], references: [id], onDelete: Cascade)
  attendances BibleSchoolAttendance[]

  @@unique([classId, date])
  @@index([classId, date])
}

model BibleSchoolAttendance {
  id        Int     @id @default(autoincrement())
  lessonId  Int
  memberId  Int
  isPresent Boolean @default(true)

  lesson BibleSchoolLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  member Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([lessonId, memberId])
}

// ===============================================
// PROFESSORES DA CLASSE
// ===============================================
model ClassTeacher {
  id       Int @id @default(autoincrement())
  memberId Int
  classId  Int

  member Member           @relation(fields: [memberId], references: [id], name: "TeachingAssignments", onDelete: Cascade)
  class  BibleSchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([memberId, classId])
}

// ===============================================
// EVENTOS / PROGRAMAÇÕES
// ===============================================
model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  startTime   DateTime?
  endTime     DateTime?
  isPublic            Boolean   @default(false)
  requiresAttendance  Boolean   @default(true)   // ← novo

  // Grupos sem InternalSociety (ex.: "ebd", "diaconia", "conselho", "ministerio").
  // Eventos de sociedade continuam usando societyId; category fica null nesse caso.
  category  String?

  societyId Int?
  society   InternalSociety? @relation(fields: [societyId], references: [id], onDelete: SetNull)

  attendances Attendance[]
  visitorAttendances VisitorAttendance[]
}

// ===============================================
// PRESENÇA (Attendance)
// ===============================================
model Attendance {
  id       Int  @id @default(autoincrement())
  memberId Int
  eventId  Int?

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  event  Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  isPresent Boolean @default(true)
}

// ===============================================
// VISITANTE (Visitor)
// Pessoa que frequenta sem ser membro. Escopo igual ao de Event:
// societyId (sociedades internas) OU category ("ebd","diaconia",
// "conselho","ministerio"). Ambos nulos = visitante geral da igreja.
// ===============================================
model Visitor {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  gender    Gender?
  birthDate DateTime?
  notes     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  societyId Int?
  society   InternalSociety? @relation(fields: [societyId], references: [id], onDelete: SetNull)
  category  String?

  attendances VisitorAttendance[]

  @@index([societyId])
  @@index([category])
}

// ===============================================
// PRESENÇA DE VISITANTE (VisitorAttendance)
// ===============================================
model VisitorAttendance {
  id        Int @id @default(autoincrement())
  visitorId Int
  eventId   Int?

  visitor Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  isPresent Boolean @default(true)

  @@unique([visitorId, eventId])
  @@index([eventId])
}

// ===============================================
// AVISOS (Notice)
// ===============================================
model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  createdAt DateTime @default(now())
}

// ===============================================
// FINANCEIRO (Finance)
// ===============================================
enum FinanceType {
  ENTRADA
  SAIDA
}

model Finance {
  id          Int         @id @default(autoincrement())
  description String
  type        FinanceType
  value       Float
  date        DateTime    @default(now())
  month       Int
  year        Int

  councilId Int?
  council   Council? @relation(fields: [councilId], references: [id], onDelete: SetNull)

  societyId Int?
  society   InternalSociety? @relation(fields: [societyId], references: [id], onDelete: SetNull)
}

// ===============================================
// DOCUMENTOS (Document)
// ===============================================
model Document {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  createdAt   DateTime @default(now())

  societyId   Int?
  society     InternalSociety? @relation(fields: [societyId], references: [id], onDelete: Cascade)

  councilId   Int?
  council     Council?         @relation(fields: [councilId], references: [id], onDelete: Cascade)

  diaconateId Int?
  diaconate   Diaconate?       @relation(fields: [diaconateId], references: [id], onDelete: Cascade)

  ministryId  Int?
  ministry    Ministry?        @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  bibleSchoolClassId Int?
  bibleSchoolClass   BibleSchoolClass? @relation(fields: [bibleSchoolClassId], references: [id], onDelete: Cascade)

  // Documento "EBD geral": aparece para todas as turmas da Escola Bíblica
  bibleSchoolGeneral Boolean @default(false)
}

// ===============================================
// BROADCAST (Comunicados)
// ===============================================
model Broadcast {
  id         Int      @id @default(autoincrement())
  title      String
  message    String
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())

  societyId  Int
  society    InternalSociety @relation(fields: [societyId], references: [id], onDelete: Cascade)

  authorName String
  authorRole String

  reactions  BroadcastReaction[]
}

model BroadcastReaction {
  id          Int      @id @default(autoincrement())
  emoji       String
  userId      String
  userName    String
  createdAt   DateTime @default(now())

  broadcastId Int
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, userId, emoji])
}

// ===============================================
// GALERIA (Gallery)
// ===============================================
model GalleryAlbum {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  coverUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  societyId          Int?
  society            InternalSociety?  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  councilId          Int?
  council            Council?          @relation(fields: [councilId], references: [id], onDelete: Cascade)

  diaconateId        Int?
  diaconate          Diaconate?        @relation(fields: [diaconateId], references: [id], onDelete: Cascade)

  ministryId         Int?
  ministry           Ministry?         @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  bibleSchoolClassId Int?
  bibleSchoolClass   BibleSchoolClass? @relation(fields: [bibleSchoolClassId], references: [id], onDelete: Cascade)

  photos GalleryPhoto[]
}

model GalleryPhoto {
  id        Int      @id @default(autoincrement())
  url       String
  caption   String?
  albumId   Int
  createdAt DateTime @default(now())

  album GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

// ===============================================
// TAREFAS DA DIACONIA
// ===============================================
enum TaskPriority {
  ALTA
  MEDIA
  BAIXA
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}

model DiaconateTask {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  priority    TaskPriority @default(MEDIA)
  status      TaskStatus   @default(PENDENTE)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  diaconateId Int
  diaconate   Diaconate    @relation(fields: [diaconateId], references: [id], onDelete: Cascade)
}

// ===============================================
// INVENTÁRIO DA DIACONIA
// ===============================================
enum ItemCondition {
  BOM
  REGULAR
  RUIM
}

model DiaconateInventory {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  quantity    Int           @default(1)
  category    String?
  condition   ItemCondition @default(BOM)
  location    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  diaconateId Int
  diaconate   Diaconate     @relation(fields: [diaconateId], references: [id], onDelete: Cascade)
}

// ===============================================
// ESCALA DA DIACONIA (DiaconateSchedule)
// ===============================================
enum ScheduleType {
  DOMINGO
  EVENTO
}

model DiaconateSchedule {
  id        Int          @id @default(autoincrement())
  title     String?      // Nome do evento (opcional quando for domingo)
  type      ScheduleType @default(DOMINGO)
  date      DateTime
  notes     String?
  createdAt DateTime     @default(now())

  diaconateId Int
  diaconate   Diaconate  @relation(fields: [diaconateId], references: [id], onDelete: Cascade)

  members DiaconateScheduleMember[]

  @@index([diaconateId, date])
}

model DiaconateScheduleMember {
  id         Int @id @default(autoincrement())
  scheduleId Int
  memberId   Int

  schedule DiaconateSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  member   Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, memberId])
}

// Indisponibilidade de um diácono para uma data (domingo).
// Usada pela escala automática para não escalar quem não pode.
model DiaconateUnavailability {
  id       Int      @id @default(autoincrement())
  memberId Int
  date     DateTime // dia "puro" (meia-noite UTC)
  reason   String?
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, date])
  @@index([date])
}

// ===============================================
// CONTATO DE VISITANTE (VisitorContact)
// Interessados que usaram o "Quero conhecer/visitar" na home pública.
// ===============================================
model VisitorContact {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  message   String?
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ===============================================
// CAPA DOS GRUPOS (GroupCover)
// Imagem de fundo/capa personalizável de cada grupo (sociedades, diaconia,
// conselho, ministério, EBD). Chaveado pela "role" do grupo.
// ===============================================
model GroupCover {
  role          String   @id  // "ump","upa","uph","saf","ucp","diaconia","conselho","ministerio","ebd"
  coverImageUrl String
  updatedAt     DateTime @updatedAt
}

// ===============================================
// REGISTRO DE ACESSOS (AccessLog)
// Quem entrou no sistema, quando e em qual página. `event`:
//   "login"    → sessão iniciada (vem do webhook do Clerk)
//   "pageview" → abertura de uma página do painel
// ===============================================
model AccessLog {
  id        Int      @id @default(autoincrement())
  event     String
  userId    String?
  userName  String?
  roles     String[]
  path      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([event, createdAt])
  @@index([userId, createdAt])
}

// ===============================================
// SERMÕES (Sermon)
// Espaço de escrita PESSOAL do pastor: rascunhos e sermões prontos.
// Sempre privado ao autor (authorId = Clerk userId). O campo `status` já
// prepara uma futura publicação.
// ===============================================
model Sermon {
  id         Int       @id @default(autoincrement())
  authorId   String    // Clerk userId do autor
  authorName String
  title      String
  passage    String?   // texto base, ex.: "Hebreus 13:8"
  content    String?   // corpo em texto (compatibilidade / busca)
  blocks     Json?     // estrutura do sermão: [{ id, type, text }]
  date       DateTime? // data prevista/da pregação
  series     String?   // série de pregações, ex.: "Efésios"
  tags       String[]  // ocasião/tema: "evangelístico", "funeral", "ceia"...
  preachedAt DateTime[] // histórico: quando este sermão já foi pregado
  status     String    @default("rascunho") // "rascunho" | "pronto"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([authorId, updatedAt])
}

// ===============================================
// DIÁRIO DO PASTOR (PastorDiaryEntry)
// Registro pessoal do pastor: visitas, aconselhamentos, cultos, reuniões.
// authorId = Clerk userId do pastor autor da entrada.
// ===============================================
model PastorDiaryEntry {
  id          Int      @id @default(autoincrement())
  authorId    String   // Clerk userId do pastor
  authorName  String
  category    String   // "Visita" | "Aconselhamento" | "Culto" | "Reunião" | "Outro"
  title       String
  description String?
  visits      Int      @default(0)
  isPrivate   Boolean  @default(false)  // confidencial: só o autor vê título e relato
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([authorId, date])
}

// ===============================================
// CONFIGURAÇÕES DA IGREJA (ChurchSettings)
// ===============================================
model ChurchSettings {
  id                Int      @id @default(1)
  churchName        String?
  youtubeChannelUrl String?
  // Dados para o Saiba Mais
  pastor            String?
  founded           String?
  city              String?
  state             String?
  address           String?
  phone             String?
  email             String?
  website           String?
  about             String?  // Texto de apresentação
  photoUrl          String?  // Foto da igreja (futuramente upload)
  mapsUrl           String?  // Link do Google Maps
  pastorCoverUrl    String?  // Capa/imagem do card do Painel do Pastor
  whatsapp          String?  // Número de WhatsApp p/ o "Quero visitar" (só dígitos, com DDD)
  slug              String?  // Identificador da igreja (base do subdomínio), ex.: "ipbtoledo"
  preferences       Json?    // Preferências gerais (toggles de notificação, privacidade, membros)
  updatedAt         DateTime @updatedAt
}


