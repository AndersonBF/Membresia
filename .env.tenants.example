# ─────────────────────────────────────────────────────────────
# Multi-igreja (híbrido: 1 app, 1 banco por subdomínio)
# Copie estas variáveis para o seu .env de PRODUÇÃO e preencha.
# Sem elas, o app funciona normalmente em modo single-tenant (usa DATABASE_URL).
# ─────────────────────────────────────────────────────────────

# Domínio base (para extrair o subdomínio do Host)
TENANT_BASE_DOMAIN=membrese.com

# Igreja usada quando não há subdomínio (localhost, domínio base)
DEFAULT_TENANT=ipbtoledo

# Subdomínios de demonstração (mostram a faixa "Ambiente de demonstração")
DEMO_TENANTS=igreja

# Um banco por igreja — use as URLs POOLED do Neon.
# Formato: TENANT_DB__<slug em minúsculas>=<DATABASE_URL>
TENANT_DB__ipbtoledo=postgresql://USER:PASS@HOST-pooler.neon.tech/ipbtoledo?sslmode=require
TENANT_DB__igreja=postgresql://USER:PASS@HOST-pooler.neon.tech/demo?sslmode=require

# Para adicionar uma igreja nova:
#   1) crie o banco no Neon
#   2) adicione TENANT_DB__<slug>=<url> aqui
#   3) npm run migrate:all
#   4) semeie o ChurchSettings (nome, slug, whatsapp) do novo banco
#   5) crie o admin no Clerk com publicMetadata: { roles:["admin"], church:"<slug>" }
